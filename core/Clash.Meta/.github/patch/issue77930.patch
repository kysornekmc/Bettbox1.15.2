diff --git a/src/internal/runtime/syscall/linux/syscall_linux.go b/src/internal/runtime/syscall/linux/syscall_linux.go
index 1a2b3c4d5e6f7a..2b3c4d5e6f7a8b 100644
--- a/src/internal/runtime/syscall/linux/syscall_linux.go
+++ b/src/internal/runtime/syscall/linux/syscall_linux.go
@@ -10,6 +10,20 @@ package linux
 	"unsafe"
 )
 
+// Utsname represents the kernel's utsname structure.
+type Utsname struct {
+	Sysname    [65]byte
+	Nodename   [65]byte
+	Release    [65]byte
+	Version    [65]byte
+	Machine    [65]byte
+	Domainname [65]byte
+}
+
+func Uname(buf *Utsname) error {
+	return syscall.Syscall6(SYS_UNAME, uintptr(unsafe.Pointer(buf)), 0, 0, 0, 0, 0)
+}
+
 func Fcntl(fd, cmd, arg int) (int, error) {
 	return syscall.Syscall6(SYS_FCNTL, uintptr(fd), uintptr(cmd), uintptr(arg), 0, 0, 0)
 }

diff --git a/src/runtime/os_linux.go b/src/runtime/os_linux.go
index 3d4e5f6a7b8c9d..4e5f6a7b8c9d0e 100644
--- a/src/runtime/os_linux.go
+++ b/src/runtime/os_linux.go
@@ -100,6 +100,68 @@ func osinit() {
 	ncpu = getproccount()
 }
 
+// supports64BitTime checks if the kernel supports 64-bit time syscalls.
+// It uses uname to check the kernel version instead of probing with ENOSYS.
+// This avoids issues on Android <= 10 (seccomp kills the process) and
+// Synology Linux (custom vendor syscall conflicts).
+func supports64BitTime() bool {
+	var utsname linux.Utsname
+	if err := linux.Uname(&utsname); err != nil {
+		// If uname fails, fall back to assuming no 64-bit time support
+		return false
+	}
+
+	// Parse release string like "5.4.0-123-generic" or "4.9.160"
+	release := string(utsname.Release[:])
+	// Find null terminator
+	for i, b := range release {
+		if b == 0 {
+			release = release[:i]
+			break
+		}
+	}
+
+	// Parse major.minor version
+	parts := strings.Split(release, ".")
+	if len(parts) < 2 {
+		return false
+	}
+
+	major, err := strconv.Atoi(parts[0])
+	if err != nil {
+		return false
+	}
+
+	// 64-bit time syscalls were added in Linux 5.1
+	// See: https://github.com/torvalds/linux/commit/48166e60
+	if major > 5 {
+		return true
+	}
+	if major < 5 {
+		return false
+	}
+
+	// major == 5, check minor
+	minor, err := strconv.Atoi(parts[1])
+	if err != nil {
+		return false
+	}
+
+	return minor >= 1
+}
+
+// has64BitTime is cached result of supports64BitTime.
+// Accessed only via atomic operations.
+var has64BitTime uint32
+
+// check64BitTime returns true if the kernel supports 64-bit time syscalls.
+// The result is cached after the first call.
+func check64BitTime() bool {
+	if atomic.Load(&has64BitTime) == 0 {
+		if supports64BitTime() {
+			atomic.Store(&has64BitTime, 2)
+		} else {
+			atomic.Store(&has64BitTime, 1)
+		}
+	}
+	return atomic.Load(&has64BitTime) == 2
+}
+
 // Linux futex.
 //
 // futexsleep(uint32 *addr, uint32 val, int64 ns)

diff --git a/src/runtime/os_linux32.go b/src/runtime/os_linux32.go
index 5e6f7a8b9c0d1e..6f7a8b9c0d1e2f 100644
--- a/src/runtime/os_linux32.go
+++ b/src/runtime/os_linux32.go
@@ -10,25 +10,15 @@ package runtime
 //
 // On 64-bit kernels, the 64-bit time syscalls are always available.
 // On 32-bit kernels, they were added in Linux 5.1.
-//
-// We probe for support by attempting a 64-bit time syscall with a
-// pointer that will cause EFAULT. If we get ENOSYS, the syscall is
-// not available. However, this probing causes issues on:
-//
-// - Android <= 10: seccomp kills the process on unknown syscalls
-// - Synology Linux: custom vendor syscalls conflict with our probe
-//
-// Instead, we use uname to check the kernel version.
 
 //go:nosplit
 func setTimespec(sec, nsec int64) linux.Timespec {
-	return linux.Timespec{Sec: int32(sec), Nsec: int32(nsec)}
-	// TODO: Use 64-bit time syscalls when available
-	// if check64BitTime() {
-	// 	return linux.Timespec{Sec: sec, Nsec: nsec}
-	// }
-	// return linux.Timespec{Sec: int32(sec), Nsec: int32(nsec)}
+	if check64BitTime() {
+		return linux.Timespec{Sec: sec, Nsec: nsec}
+	}
+	return linux.Timespec{Sec: int32(sec), Nsec: int32(nsec)}
 }
 
 //go:nosplit
 func setTimeval(sec, usec int64) linux.Timeval {
-	return linux.Timeval{Sec: int32(sec), Usec: int32(usec)}
+	if check64BitTime() {
+		return linux.Timeval{Sec: sec, Usec: usec}
+	}
+	return linux.Timeval{Sec: int32(sec), Usec: int32(usec)}
 }

